<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat Code Coverage">
        <Configuration>
          <Format>opencover</Format>
          <ExcludeByFile>
            **/Program.cs,
            **/*.g.cs
          </ExcludeByFile>
          <ExcludeByAttribute>
            GeneratedCodeAttribute
          </ExcludeByAttribute>
          <Exclude>
            [*.Test]*,
            [Cdk]*
          </Exclude>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>